# CyberHeal AI 7 - Production Environment Variables Template

# Database
DB_URL=postgresql://cyberheal:password@localhost:5432/cyberheal_db

# Security & Encryption (GENERATE STRONG KEYS FOR PROD)
SECRET_KEY=super-secret-jwt-key
ENCRYPTION_KEY=32-url-safe-base64-encoded-fernet-key=
CYBERHEAL_API_KEY=your-secure-webhook-api-key

# Threat Intelligence API Keys (Optional but recommended)
VT_API_KEY=
ABUSEIPDB_API_KEY=
ALIENVAULT_API_KEY=
NVD_API_KEY=

# LLM Reasoning Configuration (ollama, openai, azure)
LLM_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434/api/generate
# OPENAI_API_KEY=sk-...
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# MOCK_AUTH should be False in production unless testing locally
MOCK_AUTH=False
